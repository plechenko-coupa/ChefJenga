{
  "name": "Chef Jenga",
  "remoteUser": "ubuntu",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteEnv": {
    "GEM_HOME": "/tmp/.gem",
    "PATH": "/tmp/.gem/bin:${containerEnv:PATH}"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder}/workspace,target=/workspace,type=bind,consistency=cached",
  "postCreateCommand": "${containerWorkspaceFolder}/init.sh",
  "waitFor": "postCreateCommand",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vsliveshare.vsliveshare",
        "chef-software.chef",
        "Shopify.ruby-lsp"
      ]
    }
  }
}
