{
  // "name": "CWP Dev Container",
  // "remoteUser": "vscode",
  "remoteUser": "ubuntu",
  "build": {
    "dockerfile": "Dockerfile",
  },
  "containerEnv": {
    "GEM_HOME": "${containerWorkspaceFolder}/.gem"
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder}/workspace,target=/workspace,type=bind,consistency=cached",
  "postCreateCommand": [
    "${containerWorkspaceFolder}/init.sh",
    "bundler install"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vsliveshare.vsliveshare",
        "chef-software.chef",
        "Shopify.ruby-lsp"
      ]
    }
  }
}
